<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:background="@color/surface">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DRIZZX PROJECT"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/cyan"
            android:letterSpacing="0.08"
            android:fontFamily="monospace"/>

        <LinearLayout
            android:id="@+id/shizuku_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card"
            android:padding="6dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <View
                android:id="@+id/shizuku_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_red"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/shizuku_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shizuku: Tidak Aktif"
                android:textSize="11sp"
                android:textColor="@color/text_dim"
                android:fontFamily="monospace"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Fragment Container -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/surface"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/nav_launcher"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Launcher"
            android:textSize="11sp"
            android:gravity="center"
            android:textColor="@color/text_dim"
            android:padding="8dp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/nav_tweaks"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tweaks"
            android:textSize="11sp"
            android:gravity="center"
            android:textColor="@color/text_dim"
            android:padding="8dp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/nav_sensiup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SensiUp"
            android:textSize="11sp"
            android:gravity="center"
            android:textColor="@color/text_dim"
            android:padding="8dp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/nav_debug"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Debug"
            android:textSize="11sp"
            android:gravity="center"
            android:textColor="@color/text_dim"
            android:padding="8dp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Profile"
            android:textSize="11sp"
            android:gravity="center"
            android:textColor="@color/cyan"
            android:padding="8dp"
            android:textStyle="bold"/>

    </LinearLayout>
</LinearLayout>
