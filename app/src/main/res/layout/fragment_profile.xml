<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Logo / Brand -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_card"
            android:padding="24dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DZ"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="@color/cyan"
                android:fontFamily="monospace"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DRIZZX PROJECT"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text"
                android:letterSpacing="0.1"
                android:layout_marginTop="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="By @DirGa2634"
                android:textSize="12sp"
                android:textColor="@color/text_dim"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Shizuku Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tv_shizuku_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Izin Shizuku diperlukan"
                android:textSize="14sp"
                android:textColor="@color/cyan"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Version: 13.x"
                android:textSize="11sp"
                android:textColor="@color/text_dim"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/btn_shizuku"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Berikan akses Shizuku"
                android:textSize="13sp"
                android:textColor="@color/bg"
                android:background="@drawable/bg_btn_cyan"
                android:padding="12dp"
                android:gravity="center"
                android:layout_marginTop="12dp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Profile Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lisensi" android:textSize="12sp" android:textColor="@color/cyan" android:textStyle="bold" android:minWidth="100dp"/>
                <TextView android:id="@+id/tv_lisensi" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FREE" android:textSize="13sp" android:textColor="@color/text"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/divider"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Status" android:textSize="12sp" android:textColor="@color/cyan" android:textStyle="bold" android:minWidth="100dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ACTIVE" android:textSize="13sp" android:textColor="@color/text"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Device Specification -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Device Specification"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card">

            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Phone" android:textSize="12sp" android:textColor="@color/cyan" android:textStyle="bold" android:minWidth="100dp"/>
                <TextView android:id="@+id/tv_phone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textSize="12sp" android:textColor="@color/text"/>
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/divider"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Android" android:textSize="12sp" android:textColor="@color/cyan" android:textStyle="bold" android:minWidth="100dp"/>
                <TextView android:id="@+id/tv_android" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textSize="12sp" android:textColor="@color/text"/>
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/divider"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Resolution" android:textSize="12sp" android:textColor="@color/cyan" android:textStyle="bold" android:minWidth="100dp"/>
                <TextView android:id="@+id/tv_resolution" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textSize="12sp" android:textColor="@color/text"/>
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/divider"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ABI &amp; Kernel" android:textSize="12sp" android:textColor="@color/cyan" android:textStyle="bold" android:minWidth="100dp"/>
                <TextView android:id="@+id/tv_abi" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textSize="12sp" android:textColor="@color/text"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
