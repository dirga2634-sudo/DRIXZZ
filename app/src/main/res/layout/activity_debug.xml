<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080810">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#0f0f1a"
        app:titleTextColor="#00d4ff"
        app:navigationIconTint="#00d4ff" />

    <!-- Shizuku badge + shortcuts -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#0f0f1a"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_shizuku_badge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="● Shizuku OFF"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textColor="@color/red"
            android:paddingStart="8dp"/>

        <Button
            android:id="@+id/btn_dev_info"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="DevInfo"
            android:textSize="11sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_list_pkg"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Packages"
            android:textSize="11sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_whoami"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="whoami"
            android:textSize="11sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_grant_self"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Grant"
            android:textSize="11sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    </LinearLayout>

    <!-- Console output -->
    <ScrollView
        android:id="@+id/scroll_console"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#05050e"
        android:padding="4dp">

        <TextView
            android:id="@+id/tv_console"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textColor="#a0ffa0"
            android:lineSpacingMultiplier="1.3"
            android:padding="8dp"
            android:text=""/>

    </ScrollView>

    <!-- Command input -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#0f0f1a"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$ "
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:textColor="#00d4ff"
            android:layout_marginEnd="4dp"/>

        <EditText
            android:id="@+id/et_command"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="ketik command..."
            android:textColor="#c0ffc0"
            android:textColorHint="#444466"
            android:background="@null"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:singleLine="true"/>

        <Button
            android:id="@+id/btn_run"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="RUN"
            android:textSize="12sp"
            android:textStyle="bold"
            style="@style/Widget.MaterialComponents.Button"
            android:backgroundTint="#00d4ff"
            android:textColor="#000000"
            android:layout_marginStart="8dp"/>

        <Button
            android:id="@+id/btn_clear"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="CLR"
            android:textSize="12sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginStart="4dp"/>

    </LinearLayout>

</LinearLayout>
