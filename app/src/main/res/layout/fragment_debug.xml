<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#05050e">

    <!-- Shortcut buttons -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="8dp" android:background="#0f0f1a">
        <TextView android:id="@+id/tv_shizuku_badge" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Shizuku OFF" android:textSize="11sp" android:fontFamily="monospace" android:textColor="@color/red" android:paddingStart="4dp" android:gravity="center_vertical"/>
        <TextView android:id="@+id/btn_dev_info" android:layout_width="wrap_content" android:layout_height="32dp" android:text="DevInfo" android:textSize="10sp" android:textColor="@color/cyan" android:background="@drawable/bg_btn_outline" android:gravity="center" android:paddingStart="10dp" android:paddingEnd="10dp" android:layout_marginEnd="4dp"/>
        <TextView android:id="@+id/btn_list_pkg" android:layout_width="wrap_content" android:layout_height="32dp" android:text="Packages" android:textSize="10sp" android:textColor="@color/cyan" android:background="@drawable/bg_btn_outline" android:gravity="center" android:paddingStart="10dp" android:paddingEnd="10dp" android:layout_marginEnd="4dp"/>
        <TextView android:id="@+id/btn_whoami" android:layout_width="wrap_content" android:layout_height="32dp" android:text="whoami" android:textSize="10sp" android:textColor="@color/cyan" android:background="@drawable/bg_btn_outline" android:gravity="center" android:paddingStart="10dp" android:paddingEnd="10dp"/>
    </LinearLayout>

    <!-- Console -->
    <ScrollView android:id="@+id/scroll_console" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:background="#05050e" android:padding="4dp">
        <TextView android:id="@+id/tv_console" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="11sp" android:fontFamily="monospace" android:textColor="#a0ffa0" android:lineSpacingMultiplier="1.3" android:padding="8dp"/>
    </ScrollView>

    <!-- Input -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="8dp" android:background="#0f0f1a" android:gravity="center_vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$ " android:textSize="14sp" android:fontFamily="monospace" android:textColor="@color/cyan"/>
        <EditText android:id="@+id/et_command" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="ketik command..." android:textColor="#c0ffc0" android:textColorHint="#444466" android:background="@null" android:textSize="13sp" android:fontFamily="monospace" android:imeOptions="actionDone" android:inputType="text" android:singleLine="true"/>
        <TextView android:id="@+id/btn_run" android:layout_width="wrap_content" android:layout_height="36dp" android:text="RUN" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/bg" android:background="@drawable/bg_btn_cyan" android:gravity="center" android:paddingStart="16dp" android:paddingEnd="16dp" android:layout_marginStart="8dp"/>
        <TextView android:id="@+id/btn_clear" android:layout_width="wrap_content" android:layout_height="36dp" android:text="CLR" android:textSize="12sp" android:textColor="@color/cyan" android:background="@drawable/bg_btn_outline" android:gravity="center" android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginStart="4dp"/>
    </LinearLayout>
</LinearLayout>
