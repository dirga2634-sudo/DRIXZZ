<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:background="@color/surface">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DRIZZX PROJECT"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/cyan"
            android:fontFamily="monospace"/>

        <LinearLayout
            android:id="@+id/shizuku_card"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_small"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <View
                android:id="@+id/shizuku_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_red"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/shizuku_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shizuku: Tidak Aktif"
                android:textSize="10sp"
                android:textColor="@color/text_dim"
                android:fontFamily="monospace"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Fragment Container -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="@color/surface">

        <!-- Launcher -->
        <LinearLayout
            android:id="@+id/nav_launcher"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp">
            <ImageView
                android:id="@+id/nav_icon_launcher"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_launcher"
                android:colorFilter="@color/text_dim"/>
            <TextView
                android:id="@+id/nav_launcher"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Launcher"
                android:textSize="9sp"
                android:textColor="@color/text_dim"
                android:layout_marginTop="2dp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Tweaks -->
        <LinearLayout
            android:id="@+id/nav_tweaks"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp">
            <ImageView
                android:id="@+id/nav_icon_tweaks"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_tweaks"
                android:colorFilter="@color/text_dim"/>
            <TextView
                android:id="@+id/nav_tweaks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tweaks"
                android:textSize="9sp"
                android:textColor="@color/text_dim"
                android:layout_marginTop="2dp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- SensiUp -->
        <LinearLayout
            android:id="@+id/nav_sensiup"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp">
            <ImageView
                android:id="@+id/nav_icon_sensiup"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_sensiup"
                android:colorFilter="@color/text_dim"/>
            <TextView
                android:id="@+id/nav_sensiup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SensiUp"
                android:textSize="9sp"
                android:textColor="@color/text_dim"
                android:layout_marginTop="2dp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Debug -->
        <LinearLayout
            android:id="@+id/nav_debug"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp">
            <ImageView
                android:id="@+id/nav_icon_debug"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_debug"
                android:colorFilter="@color/text_dim"/>
            <TextView
                android:id="@+id/nav_debug"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Debug"
                android:textSize="9sp"
                android:textColor="@color/text_dim"
                android:layout_marginTop="2dp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Profile -->
        <LinearLayout
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp">
            <ImageView
                android:id="@+id/nav_icon_profile"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_profile"
                android:colorFilter="@color/cyan"/>
            <TextView
                android:id="@+id/nav_profile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="9sp"
                android:textColor="@color/cyan"
                android:layout_marginTop="2dp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
